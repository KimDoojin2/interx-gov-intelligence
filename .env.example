# =============================================================================
# InterX Government Intelligence Engine — 환경변수
# 이 파일을 .env 로 복사한 후 실제 값으로 수정하세요.
# =============================================================================

# ── Google Sheets ─────────────────────────────────────────────────────────────
INTERX_SHEET_NAME=InterX_BD_CRM_v10_fresh_template
INTERX_SA_JSON=service_account.json

# ── 데이터 경로 ────────────────────────────────────────────────────────────────
INTERX_DB_PATH=data/interx_pipeline.db
INTERX_ATT_DIR=data/attachments
INTERX_LOG_DIR=logs

# ── 수집 설정 ──────────────────────────────────────────────────────────────────
INTERX_MAX_PAGES=5          # 사이트당 최대 페이지 수
INTERX_WORKERS=8            # 동시 수집 워커 수
INTERX_TIMEOUT=20           # 사이트별 요청 타임아웃 (초)
INTERX_FETCH_DETAIL=true    # 상세 페이지 방문 여부 (false=목록만)

# ── 알림 (선택) ────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Colab / Docker 환경 ──────────────────────────────────────────────────────
# INTERX_PROJECT_ROOT=/app
# INTERX_SA_JSON=/content/drive/MyDrive/interx_gov_intelligence/service_account.json
